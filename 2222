        local PageLayout = Instance.new("UIListLayout")
        PageLayout.Parent = TabPage
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding = UDim.new(0, 8)
        
        if not UI.flags._tabs then UI.flags._tabs = {} end
        table.insert(UI.flags._tabs, {Button = TabButton, Page = TabPage})
        
        if #UI.flags._tabs == 1 then
            TabPage.Visible = true
            TabButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
        end
        
        TabButton.MouseButton1Click:Connect(function()
            for _, tab in ipairs(UI.flags._tabs) do
                tab.Page.Visible = false
                tab.Button.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
            end
            TabPage.Visible = true
            TabButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
        end)
        
        return TabPage
    end
    
